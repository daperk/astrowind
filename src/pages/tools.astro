---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import Schema from '~/components/common/Schema.astro';
import { Icon } from 'astro-icon/components';

const interactiveTools = [
  {
    title: 'Sleep Calculator',
    desc: 'Best bedtimes and wake-up times based on 90-minute sleep cycles.',
    href: '/sleep-calculator',
    icon: 'tabler:calculator',
  },
  {
    title: 'Caffeine Calculator',
    desc: 'See how much caffeine is left at bedtime and your last-call time.',
    href: '/caffeine-calculator',
    icon: 'tabler:coffee',
  },
  {
    title: 'Sleep Quiz',
    desc: 'Answer 2 questions and get a personalized plan for your sleep problem.',
    href: '/sleep-quiz',
    icon: 'tabler:list-check',
  },
  {
    title: 'Sleep Sounds',
    desc: 'White, pink, and brown noise in your browser, with a sleep timer.',
    href: '/sleep-sounds',
    icon: 'tabler:wave-sine',
  },
];

const metadata = {
  title: 'Sleep Tools & Gadgets: Reviews & Recommendations | SleepUpgradeHub',
  description: 'Discover the best sleep tools, trackers, white noise machines, and bedroom gadgets. Honest reviews and science-backed recommendations to help you sleep better.',
  robots: {
    index: true,
    follow: true,
  },
};

// FAQ data for schema
const faqItems = [
  {
    question: 'What sleep tools actually work?',
    answer: 'The most effective sleep tools are those that address specific sleep challenges: blackout curtains for light control, white noise machines for sound masking, sleep trackers for habit awareness, and temperature-regulating bedding. We test and review each tool based on scientific research and real-world effectiveness.',
  },
  {
    question: 'Do I need expensive gadgets to sleep better?',
    answer: 'No. Many effective sleep improvements come from free habit changes and low-cost solutions like blackout curtains, earplugs, or a box fan. High-tech sleep trackers and smart devices can provide helpful data but are not essential for most people to improve their sleep quality.',
  },
  {
    question: 'What should I look for in a sleep tracker?',
    answer: 'Look for accurate heart rate monitoring, sleep stage detection, minimal disruption (comfortable to wear), good battery life, and actionable insights rather than just data. The best tracker is one you will actually use consistently.',
  },
  {
    question: 'Are white noise machines worth it?',
    answer: 'For many people, yes. White noise machines help mask disruptive sounds, create consistent audio environments, and can significantly improve sleep quality for light sleepers or those in noisy environments. Even a simple fan can work as an effective white noise source.',
  },
  {
    question: 'How do I choose the right sleep tools for me?',
    answer: 'Start by identifying your specific sleep challenge (falling asleep, staying asleep, waking too early, poor sleep quality). Then choose tools that directly address that issue. We provide detailed buying guides for each category to help you make informed decisions.',
  },
];
---

<!-- FAQ Schema for search engines -->
<Schema type="faqpage" faqs={faqItems} />

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero
    tagline="Sleep Tools & Gadgets"
    actions={[
      {
        variant: 'primary',
        text: 'Browse All Tools',
        href: '/category/sleep-tools',
        icon: 'tabler:bulb',
      },
      {
        text: 'Read Reviews',
        href: '/blog',
      },
    ]}
    image={{ src: '~/assets/images/tools-supplements.webp', alt: 'Sleep optimization tools and gadgets' }}
  >
    <Fragment slot="title">
      The Best <span class="text-brand">Sleep Tools & Gadgets</span> for Better Rest
    </Fragment>

    <Fragment slot="subtitle">
      Honest reviews and science-backed recommendations for sleep trackers, white noise machines, smart lights, and bedroom optimization tools that actually work.
    </Fragment>
  </Hero>

  <!-- Free Interactive Tools -->
  <section class="py-12 md:py-16 bg-gray-50">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-warm mb-2">Free Interactive Tools</p>
        <h2 class="font-heading text-3xl md:text-4xl font-semibold text-gray-900">Try Our Free Sleep Tools</h2>
        <p class="text-gray-600 mt-3">No sign-up and no download. Use them right in your browser.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {interactiveTools.map((tool) => (
          <a
            href={tool.href}
            class="group flex flex-col bg-white rounded-2xl border border-gray-200 p-6 hover:shadow-xl hover:border-brand-accent transition-all duration-300"
          >
            <div class="w-12 h-12 rounded-full bg-brand-accent/10 flex items-center justify-center mb-4 group-hover:bg-brand-accent transition">
              <Icon name={tool.icon} class="w-6 h-6 text-brand-accent group-hover:text-white" />
            </div>
            <h3 class="font-heading text-lg font-semibold text-gray-900 mb-1">{tool.title}</h3>
            <p class="text-sm text-gray-600 flex-1">{tool.desc}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-brand-accent group-hover:gap-2 transition-all">
              Open tool
              <span aria-hidden="true">&rarr;</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Overview -->
  <Content
    tagline="Why Trust Our Reviews"
    title="Sleep Tools That Make a Real Difference"
    items={[
      {
        title: 'Science-Backed Testing',
        description:
          'Every tool we review is tested against published sleep research and real-world effectiveness data.',
      },
      {
        title: 'Honest Recommendations',
        description:
          'We prioritize your sleep quality over affiliate commissions. If a product does not work, we tell you.',
      },
      {
        title: 'Practical Use Cases',
        description:
          'We test tools in real bedrooms for real people: parents, shift workers, light sleepers, and everyone in between.',
      },
    ]}
    image={{
      src: '~/assets/images/tools-supplements.webp',
      alt: 'Sleep optimization tools and gadgets',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Cutting through the noise
      </h3>
      The sleep gadget market is full of marketing hype and pseudoscience. We test, review, and recommend only the tools that deliver measurable sleep improvements based on scientific principles.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50/60"></div>
    </Fragment>
  </Content>

  <!-- Featured Articles -->
  <BlogLatestPosts
    title="Latest Sleep Tool Reviews & Guides"
    information="Explore our in-depth reviews, buying guides, and comparison articles for sleep optimization tools and bedroom gadgets."
  />

  <!-- FAQs -->
  <FAQs
    title="Sleep Tools FAQs"
    subtitle="Common questions about sleep optimization tools and gadgets"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={faqItems.map(item => ({
      title: item.question,
      description: item.answer,
    }))}
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Browse All Tool Guides',
        href: '/category/sleep-tools',
        icon: 'tabler:book',
      },
      {
        text: 'View All Sleep Guides',
        href: '/blog',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to Upgrade Your Sleep Setup?
    </Fragment>

    <Fragment slot="subtitle">
      Browse our comprehensive guides and reviews to find the perfect sleep optimization tools for your needs.
    </Fragment>
  </CallToAction>
</Layout>

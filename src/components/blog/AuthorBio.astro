---
/**
 * Author bio block (end of article). Honest brand-persona byline: no fabricated
 * credentials, links to the About/editorial page for E-E-A-T.
 */
import { Icon } from 'astro-icon/components';

export interface Props {
  author?: string;
  bio?: string;
}

const {
  author = 'The SleepUpgradeHub Editorial Team',
  bio = 'We are an independent team that researches sleep products and the science behind them, then writes honest, practical guides. We are not doctors, and our content is general information, not medical advice.',
} = Astro.props;
---

<div class="py-8 border-t border-gray-200">
  <div class="flex items-start gap-5 bg-gray-50 rounded-xl p-6 md:p-8">
    <div class="flex-shrink-0">
      <div class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-gradient-to-br from-brand-primary to-brand-accent text-white flex items-center justify-center text-2xl md:text-3xl font-bold shadow-lg">
        S
      </div>
    </div>
    <div class="flex-1">
      <p class="text-xs font-semibold uppercase tracking-wide text-brand-accent mb-1">Written by</p>
      <h3 class="font-heading text-lg md:text-xl font-semibold text-gray-900 mb-2">
        {author}
      </h3>
      <p class="text-sm md:text-base text-gray-700 leading-relaxed mb-3">
        {bio}
      </p>
      <div class="flex flex-wrap items-center gap-4 text-xs text-gray-500">
        <span class="flex items-center gap-1">
          <Icon name="tabler:search" class="w-4 h-4" />
          Independent research
        </span>
        <span class="flex items-center gap-1">
          <Icon name="tabler:shield-check" class="w-4 h-4" />
          No sponsored reviews
        </span>
        <a href="/about" class="flex items-center gap-1 text-brand-accent hover:underline">
          <Icon name="tabler:info-circle" class="w-4 h-4" />
          About our process
        </a>
      </div>
    </div>
  </div>
</div>

---
/**
 * Night hero — full-bleed calming bedroom image with a legibility gradient,
 * light type, and a clear primary action. On-brand "night" signature moment.
 */
import Image from '~/components/common/Image.astro';
import heroImage from '~/assets/images/hero-night.webp';

export interface Props {
  title?: string;
  subtitle?: string;
  eyebrow?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  ctaText = 'Start with the basics',
  ctaHref = '/optimize-bedroom-environment-for-better-sleep',
  secondaryText = 'Browse all guides',
  secondaryHref = '/blog',
} = Astro.props;
---

<section class="relative overflow-hidden bg-brand-primary">
  <!-- Background night image + legibility gradient -->
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      class="w-full h-full object-cover object-right"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-brand-primary via-brand-primary/90 to-brand-primary/40"></div>
    <div class="absolute inset-0 bg-brand-primary/30 md:hidden"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-32">
    <div class="max-w-2xl">
      {eyebrow && (
        <p class="inline-flex items-center gap-3 text-xs font-semibold text-brand-warm uppercase tracking-[0.2em] mb-5">
          <span class="w-8 h-px bg-brand-warm" aria-hidden="true"></span>
          {eyebrow}
        </p>
      )}
      {title && (
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-semibold text-white mb-5 leading-[1.08]">
          <Fragment set:html={title} />
        </h1>
      )}
      {subtitle && (
        <p class="text-lg md:text-xl text-slate-200/90 leading-relaxed mb-8 max-w-xl">
          {subtitle}
        </p>
      )}
      <div class="flex flex-wrap items-center gap-4">
        <a
          href={ctaHref}
          class="inline-flex items-center justify-center rounded-full bg-white text-brand-primary font-semibold px-7 py-3 shadow-sm hover:bg-brand-accent-light hover:text-brand-primary transition"
        >
          {ctaText}
        </a>
        <a
          href={secondaryHref}
          class="inline-flex items-center justify-center rounded-full border border-white/40 text-white font-medium px-7 py-3 hover:bg-white/10 transition"
        >
          {secondaryText}
        </a>
      </div>
    </div>
  </div>
</section>
